              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass123\",\n  \"name\": \"Raju Kumar\",\n  \"language\": \"hi\",\n  \"businessType\": \"retail\",\n  \"region\": [\"UP\", \"MP\"]\n}"
            },
            "url": {
